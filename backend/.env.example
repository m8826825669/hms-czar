# ─── Django ──────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=change-me-in-production-use-secrets-token-urlsafe-50
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend

# ─── Database (PostgreSQL) ───────────────────────────────
POSTGRES_DB=hms
POSTGRES_USER=hms
POSTGRES_PASSWORD=hms
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ─── Redis ───────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── CORS / Frontend origin ──────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ─── Hospital defaults ───────────────────────────────────
HMS_DEFAULT_HOSPITAL_CODE=HOSP001
HMS_MRN_PREFIX=MRN
HMS_MRN_PADDING=8

# ─── Razorpay (test creds) ───────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# ─── MSG91 (SMS / WhatsApp / OTP) ────────────────────────
MSG91_AUTH_KEY=
MSG91_SENDER_ID=HMSCRE
MSG91_OTP_TEMPLATE_ID=

# ─── Legacy MySQL (for one-time data migration) ─────────
LEGACY_MYSQL_HOST=
LEGACY_MYSQL_PORT=3306
LEGACY_MYSQL_USER=
LEGACY_MYSQL_PASSWORD=
LEGACY_MYSQL_DB=

# ─── Production-only: S3 / MinIO file storage ───────────
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_REGION_NAME=ap-south-1
# AWS_S3_ENDPOINT_URL=
